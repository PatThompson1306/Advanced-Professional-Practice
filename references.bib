	address = {Cham},
	edition = {null},
	series = {null},
	title = {The multidimensional online grooming questionnaire.},
	volume = {null},
	isbn = {978-3-031-31546-6 978-3-031-31547-3},
	url = {https://research.ebsco.com/plink/e8f65436-aab6-3554-8f77-1e83b84d019a},
