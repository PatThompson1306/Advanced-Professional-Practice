@article{winters2022universal,
	title = {Toward a {Universal} {Definition} of {Child} {Sexual} {Grooming}},
	volume = {43},
	issn = {0163-9625},
	url = {https://doi.org/10.1080/01639625.2021.1941427},
	doi = {10.1080/01639625.2021.1941427},
	abstract = {It is estimated that 30–45\% of child sexual abusers use sexual grooming tactics. While sexual grooming is considered integral to the child sexual abuse process, there has yet to be a universally accepted definition of the construct that condenses and summarizes this complex process. Based upon a thorough evaluation and critique of prior definitions and research on a content validated model of sexual grooming, a new operational definition of sexual grooming is proposed. An easily understood and applied definition of sexual grooming is needed for measurement of the construct. Further, having a common language to describe sexual grooming is necessary for research, communication, detection, prevention, and intervention of child sexual abuse.},
	number = {8},
	urldate = {2026-05-10},
	journal = {Deviant Behavior},
	publisher = {Routledge},
	author = {Winters, Georgia M. and Kaylor, Leah E. and Jeglic, Elizabeth L.},
	month = aug,
	year = {2022},
	note = {\_eprint: https://doi.org/10.1080/01639625.2021.1941427},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
	pages = {926--938},
}

@article{winters2020validation,
	title = {Validation of the {Sexual} {Grooming} {Model} of {Child} {Sexual} {Abusers}},
	volume = {29},
	issn = {1053-8712},
	url = {https://doi.org/10.1080/10538712.2020.1801935},
	doi = {10.1080/10538712.2020.1801935},
	abstract = {Sexual grooming has been deemed an integral part of the child sexual abuse process. However, there has yet to be a universally accepted model for this process and, as a consequence, there is no clear understanding of which behaviors constitute sexual grooming. One proposed model of in-person sexual grooming outlined five stages of the process: 1) victim selection, 2) gaining access and isolating a child, 3) trust development, 4) desensitization to sexual content and physical contact, and 5) maintenance following the abuse. The present study sought to validate this Sexual Grooming Model (SGM) and identify behaviors that may be employed during each stage of the process. First, a thorough review of the literature was conducted to generate a comprehensive list of sexual grooming behaviors (n = 77). Second, 18 experts in the field completed a survey which asked them to rate the extent to which each of the five stages and potential grooming behaviors were relevant to the sexual grooming process. Results provided support for the SGM and produced 42 behaviors that were considered to be grooming tactics within these stages. From this, the first validated, comprehensive model of in-person sexual grooming is proposed. The article concludes with a discussion of the implications and future directions in the field.},
	number = {7},
	urldate = {2026-05-10},
	journal = {Journal of Child Sexual Abuse},
	publisher = {Routledge},
	author = {Winters, Georgia M. and Jeglic, Elizabeth L. and Kaylor, Leah E.},
	month = oct,
	year = {2020},
	note = {\_eprint: https://doi.org/10.1080/10538712.2020.1801935},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
	pages = {855--875},
}

@article{winters2017stages,
	title = {Stages of {Sexual} {Grooming}: {Recognizing} {Potentially} {Predatory} {Behaviors} of {Child} {Molesters}},
	volume = {38},
	issn = {0163-9625},
	shorttitle = {Stages of {Sexual} {Grooming}},
	url = {https://doi.org/10.1080/01639625.2016.1197656},
	doi = {10.1080/01639625.2016.1197656},
	abstract = {It has been proposed that sexual grooming behaviors of child molesters are not easily identified prior to the abuse. The present study investigated whether participants could recognize grooming behaviors, and if so, identify which stages of the process were most easily identified. Participants were randomly assigned to read one of six vignettes describing the stages of the grooming process. Results revealed no differences in likelihood ratings that the person in the vignette was a child molester and would commit sexual abuse between any of the conditions, suggesting that people may be unable to identify potentially predatory behaviors of child molesters prospectively.},
	number = {6},
	urldate = {2026-05-10},
	journal = {Deviant Behavior},
	publisher = {Routledge},
	author = {Winters, Georgia M. and Jeglic, Elizabeth L.},
	month = jun,
	year = {2017},
	note = {\_eprint: https://doi.org/10.1080/01639625.2016.1197656},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
	pages = {724--733},
}

@article{winters2016knew,
	title = {I {Knew} {It} {All} {Along}: {The} {Sexual} {Grooming} {Behaviors} of {Child} {Molesters} and the {Hindsight} {Bias}.},
	volume = {25},
	issn = {1053-8712},
	shorttitle = {I {Knew} {It} {All} {Along}},
	url = {https://research.ebsco.com/linkprocessor/plink?id=2fd4ec6a-c8bf-3b76-a863-0b95843648e4},
	doi = {10.1080/10538712.2015.1108945},
	abstract = {Recent high profile cases of child sexual abuse have increased interest in the grooming behaviors of child molesters and why these offenders are not identified sooner. This study examined one possible explanation—the hindsight bias. Five hundred and twenty-six undergraduates were randomly assigned to read one of six vignettes and asked to rate the likelihood the person in the story is a child molester. Results supported the presence of the hindsight bias, with participants who were given outcome information overestimating the likelihood they would have predicted that the person was a child molester. Also, participants were able to recognize sexual grooming behaviors when the potential child molester was a relative and nonrelative. Findings indicated that sexual grooming behaviors may be more easily identified than previously proposed, but individuals greatly overestimate the likelihood they would have predicted a person was a child molester once they are given outcome information.},
	language = {eng},
	number = {1},
	urldate = {2026-05-15},
	journal = {Journal of Child Sexual Abuse},
	publisher = {Taylor \& Francis Ltd},
	author = {Winters, Georgia M. and Jeglic, Elizabeth L.},
	month = jan,
	year = {2016},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
	pages = {20--36},
}

@article{whittemore2005integrative,
	title = {The integrative review: updated methodology},
	volume = {52},
	issn = {1365-2648},
	shorttitle = {The integrative review},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1365-2648.2005.03621.x},
	doi = {10.1111/j.1365-2648.2005.03621.x},
	abstract = {Aim. The aim of this paper is to distinguish the integrative review method from other review methods and to propose methodological strategies specific to the integrative review method to enhance the rigour of the process. Background. Recent evidence-based practice initiatives have increased the need for and the production of all types of reviews of the literature (integrative reviews, systematic reviews, meta-analyses, and qualitative reviews). The integrative review method is the only approach that allows for the combination of diverse methodologies (for example, experimental and non-experimental research), and has the potential to play a greater role in evidence-based practice for nursing. With respect to the integrative review method, strategies to enhance data collection and extraction have been developed; however, methods of analysis, synthesis, and conclusion drawing remain poorly formulated. Discussion. A modified framework for research reviews is presented to address issues specific to the integrative review method. Issues related to specifying the review purpose, searching the literature, evaluating data from primary sources, analysing data, and presenting the results are discussed. Data analysis methods of qualitative research are proposed as strategies that enhance the rigour of combining diverse methodologies as well as empirical and theoretical sources in an integrative review. Conclusion. An updated integrative review method has the potential to allow for diverse primary research methods to become a greater part of evidence-based practice initiatives.},
	language = {en},
	number = {5},
	urldate = {2026-02-20},
	journal = {Journal of Advanced Nursing},
	author = {Whittemore, Robin and Knafl, Kathleen},
	year = {2005},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1365-2648.2005.03621.x},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
	pages = {546--553},
}

@article{wefers2024understanding,
	title = {Understanding and {Deterring} {Online} {Child} {Grooming}: {A} {Qualitative} {Study}},
	volume = {19},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85188250114&doi=10.5964%2Fsotrap.13147&partnerID=40&md5=e327c6457f6cd26adf027e2bbc82b77c},
	doi = {10.5964/sotrap.13147},
	abstract = {Background Online sexual offences against children, including so-called “grooming” offences, have been increasing over recent years, particularly during the Covid-19 pandemic. These offences have severe negative impact on the children involved, the adults perpetrating the offences, and wider society. Why was this study done? This study tried to deepen our understanding why and how grooming offending happens and what can be done to help people stop this behaviour and seek help. This was done to ultimately help reduce the number of grooming offences and keep more people safe online. What did the researchers do and find? We interviewed 14 men who had been detected for their online sexual communications with minors and asked them about their pathways into offending and what they felt could be helpful in preventing grooming behaviour. We analysed the interviews and identified five themes that all related to both risk factors and protective factors for grooming behaviour. We named these themes Social Aspects, Mental Health/Psychological Aspects, Justification for Offending, Secrecy, and Technology. Participants spoke about how they used online chats to seek connections, how they felt their online behaviour got out of control, how they did not perceive online chats as ‘real’ conversations and that anonymity on the internet facilitated online grooming behaviour. What do these findings mean? The findings show that there are different reasons why some men engage in online grooming behaviour. We propose that there may be three pathways into grooming offending, namely seeking intimacy and social connections; addictive behaviours; and fantasy. There are different things that can be done to prevent this behaviour, including more education about the risks of online behaviour, the use of warning messages online, and helping people lead a positive and healthy lifestyle.},
	journal = {Sexual Offending: Theory, Research, and Prevention},
	author = {Wefers, S. and Dieseth, T. and George, E. and Øverland, I. and Jolapara, J. and McAree, C. and Findlater, D.},
	year = {2024},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
}

