@book{jay2022report,
	address = {London},
	title = {The report of the independent inquiry into child sexual abuse: a report of the {Inquiry} {Panel}},
	isbn = {978-1-5286-3653-7},
	shorttitle = {The report of the independent inquiry into child sexual abuse},
	abstract = {The sexual abuse and exploitation of children is criminal and morally wrong. There is no
excuse for those who perpetrate this crime. It has never been right or excusable whenever
it occurred. To a significant extent, this also applies to those who knew about the abuse but
did nothing, as well as to those who actively covered it up or contrived to assist a perpetrator
in escaping justice or avoiding the scrutiny of the statutory authorities.
As the Inquiry progressed, the extent of the global crisis in child sexual abuse and
exploitation became increasingly clear. This is manifested in one way by the number of
national and institutional inquiries being conducted across the world – including in the US,
Australia, Ireland, Germany, France, Spain and Japan. The extraordinary, soaring numbers of
child victims of internet-based sexual abuse also confirm the scale of the problem, providing
evidence that the sexual abuse of children cannot be conveniently committed to the annals
of history. Millions of child sexual abuse images can be accessed within just three ‘clicks’,
many of which depict young children and babies.
Nearly every one of the Inquiry’s investigation reports concluded that the true scale
of sexual abuse of children is likely to have been much higher than the actual numbers
recorded, and this continues to be the case with current methods of data-gathering.
Information collected by children’s services shows high numbers of assessments where
child sexual abuse and exploitation is identified as a risk factor, but the number of children
placed on child protection plans under the primary category of child sexual abuse is
comparatively low.},
	language = {en},
	publisher = {His Majesty's Stationery Office},
	author = {Jay, Alexis and Evans, Malcolm D. and Frank, Ivor and Sharpling, Drusilla},
	year = {2022},
	note = {OCLC: 1554886329},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
}

@inproceedings{iryna2025implementation,
	title = {The {Implementation} of {Artificial} {Intelligence} in {Criminal} {Law} {Practice}: {Challenges} and {Prospects} for {Development}},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105032754843&doi=10.1109%2FIDAACS68557.2025.11321969&partnerID=40&md5=eace56cc7099310a6b7b14f01345748e},
	doi = {10.1109/IDAACS68557.2025.11321969},
	abstract = {The application of artificial intelligence in criminal law practice is regarded as a promising avenue in the digitalisation of pre-trial investigation authorities, the prosecution service, the legal profession, and judicial proceedings. It aims to enhance the efficiency of search and analytical work, prevent crime, and assist in decisionmaking. However, this issue remains controversial due to ethical concerns and existing legislative constraints. Alternatively, one should recognize that in cases of military or other crimes involving digital traces such as video or audio recordings, artificial intelligence plays a vital role. It is an essential tool for investigative bodies in gathering and analyzing such evidence. International experience in the use of artificial intelligence in the analytical work of law enforcement agencies and the judicial system demonstrates the effectiveness of this digital tool in the daily activities of the legal community. The article presents both theoretical and practical perspectives on the impact and future development of artificial intelligence in the field of criminal law. These issues remain highly relevant for further research and discussion, particularly in the context of ethical privacy concerns.},
	author = {Iryna, Y. and Antonina, F.-M. and Yuliia, M. and Nadiia, M. and Lutsiv, R. and Andrii, K.},
	year = {2025},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
	pages = {630--635},
}

@article{inches2012overview,
	title = {Overview of the {International} {Sexual} {Predator} {Identiﬁcation} {Competition} at {PAN}-2012},
	abstract = {This contribution presents the evaluation methodology for the identiﬁcation of potential “sexual predators” in online conversations as part of PAN 2012. We provide details of the realized collection and analyse the submissions of the participants, who had to solve two problems: identify the predators among all the users in the different conversations and identify the part (the lines) of the predator conversations which are the most distinctive of the predator bad behaviour. The methods proposed by the 16 teams participating in the contest made possible the recognition of common pattern for predator identiﬁcation (e.g. no preprocessing of the conversations, lexical and behavioral analysis, blacklisting of predator terms) as well as possible extension to existing systems (e.g. victimpredator distinction, pre-ﬁltering of not relevant conversations).},
	language = {en},
	author = {Inches, Giacomo and Crestani, Fabio},
	year = {2012},
	keywords = {Theoretical Perspectives of Advanced Professional Practice},
}

